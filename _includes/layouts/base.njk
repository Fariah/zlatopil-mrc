<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - КЗ "Златопільський МРЦ"</title>
    <meta name="description" content="{{ description or 'Офіційний сайт Комунального закладу Златопільський міжшкільний ресурсний центр' }}">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    {% include "header.njk" %}

    <div class="container">
        {% include "sidebar.njk" %}
        
        <main class="content" data-cms-bind="#content">
            <nav class="breadcrumbs" aria-label="Breadcrumb">
                <a href="/">Головна</a>
                {% if page.url != "/" %}
                <span class="separator">/</span>
                <span class="current">{{ title }}</span>
                {% endif %}
            </nav>

            <div class="page-header" style="margin-bottom: 2rem; border-bottom: 2px solid var(--border-color); padding-bottom: 1rem;">
                <h2 style="color: var(--primary-color); font-size: 2rem;">{{ title }}</h2>
            </div>

            {{ content | safe }}
        </main>
    </div>

    <script src="/js/main.js"></script>
    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
</body>
</html>
